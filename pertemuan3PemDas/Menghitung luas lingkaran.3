#include <iostream>
using namespace std;

float r;
float phi = 3.14159;

void input()
{
    cout << "Masukkan jari-jari : ";
    cin >> r;
}
float luas(float r)
{
    return phi * r * r;
}
void output ()
{
    cout << "Luasnya adalah : " << luas(r) << endl;
}

int main()
{
    input();
    output();
}